{
    "env": {
        "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "85",
        "SKILL_INTERNAL": "true"
    },
    "permissions": {
        "allow": [
            "Bash(*)",
            "Read(*)",
            "Edit(*)",
            "Write(*)",
            "Write(workspace/**)",
            "Edit(workspace/**)",
            "Write(.claude/**)",
            "Edit(.claude/**)",
            "Write(squads/**)",
            "Edit(squads/**)",
            "Write(MEMORY.md)",
            "Edit(MEMORY.md)",
            "Write(AGENTS.md)",
            "Edit(AGENTS.md)",
            "Write(segundo-cerebro/**)",
            "Edit(segundo-cerebro/**)",
            "Write(CLAUDE.md)",
            "Edit(CLAUDE.md)",
            "WebSearch",
            "Skill(schedule)",
            "Skill(schedule:*)"
        ],
        "defaultMode": "bypassPermissions",
        "additionalDirectories": []
    },
    "hooks": {
        "PreCompact": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "echo '{\"hookSpecificOutput\": {\"hookEventName\": \"PreCompact\", \"additionalContext\": \"ANTES DE COMPACTAR — obrigatório, nesta ordem: (1) Atualize workspace/memoria-coo/sintese.md secao Retomar: marque cada tarefa concluida, remova canceladas com motivo. (2) Registre licoes novas em workspace/memory/aprendizados.md OU em workspace/memory/agentes/{agente}/aprendizados.md se for especifico de um agente. (3) Se decisao estrategica foi tomada, registre em workspace/memory/decisoes.md. Sem isso a proxima sessao comeca com estado errado.\"}}'"
                    }
                ]
            }
        ],
        "UserPromptSubmit": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "echo '{\"hookSpecificOutput\": {\"hookEventName\": \"UserPromptSubmit\", \"additionalContext\": \"REGRA JADE ATIVA: Você é COO — nunca produz conteúdo diretamente. Antes de qualquer ação, pergunte internamente: Estou PRODUZINDO algo ou ORQUESTRANDO alguém? Se PRODUZINDO → pare imediatamente → crie um Agent com briefing → passe para o squad correto → registre em squads/{squad}/tarefas.md.\"}}'",
                        "statusMessage": "Verificando modo Jade..."
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Write|Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-secret-creation.sh"
                    }
                ]
            },
            {
                "matcher": "Write|Edit|Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-pendencia-antes-trabalho-estrutural.sh"
                    }
                ]
            },
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-triple-check-antes-deploy.sh"
                    }
                ]
            },
            {
                "matcher": "Write|Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-bateria-testes-antes-entregue.sh"
                    }
                ]
            },
            {
                "matcher": "Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-skill-nova-sem-aval.sh"
                    }
                ]
            },
            {
                "matcher": "Edit|Write|NotebookEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-edit-em-claude-paths.sh"
                    }
                ]
            },
            {
                "matcher": "Write|Edit|Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-producao-sem-skill.sh"
                    }
                ]
            },
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-revisao-visual-antes-publicar.sh"
                    }
                ]
            },
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-caqui-parcial-regra29.sh"
                    }
                ]
            },
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-newsletter-revisao-visual.sh"
                    }
                ]
            },
            {
                "matcher": "Write|Edit|Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-jade-producao-direta.sh"
                    }
                ]
            },
            {
                "matcher": "Write|Edit|Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-pendencia-md-banido.sh"
                    }
                ]
            },
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-bash-em-claude-paths.sh",
                        "description": "Bloqueia Bash com escrita em .claude/settings.json, .claude/hooks/, .claude/commands/, .claude/agents/, ~/.claude.json, ~/.claude/mcp.json (Regra §16, vetor R2 self-modification)"
                    }
                ]
            },
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-baseline-hash-claude.sh",
                        "description": "Verifica baseline sha256 de arquivos críticos do Claude (~/.claude.json, hooks, settings) em background — Regra §16 vetor R1. NÃO bloqueia, apenas warn em divergência."
                    }
                ]
            },
            {
                "matcher": "Agent",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/check-agent-sem-skill-recente.sh"
                    }
                ]
            },
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-comandos-destrutivos.sh"
                    }
                ]
            }
        ],
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/sessionstart-jade-autoload.sh",
                        "description": "Autoload manual operacional Jade + top 5 fila ClickUp + instrução §15 (Jade decide com opinião). Regra §11/§16."
                    }
                ]
            }
        ]
    },
    "skipDangerousModePermissionPrompt": true,
    "skillOverrides": {
        "atualizar-estrategia": "on",
        "check-up-estrutura": "on",
        "configurar-squad": "on",
        "consolidar-sessao": "on",
        "criar-carrossel": "on",
        "criar-carrossel-de-video": "on",
        "criar-criativo": "on",
        "criar-pagina": "on",
        "criar-pendencia": "on",
        "escrever-copy": "on",
        "escrever-estrategia": "on",
        "escrever-linkedin": "on",
        "escrever-newsletter": "on",
        "escrever-pagina": "on",
        "escrever-roteiro": "on",
        "fechar-pendencia": "on",
        "gerar-imagem": "on",
        "jade": "on",
        "listar-pendencias": "on",
        "migrar-pagina": "on",
        "publicar-pagina": "on",
        "revisar-semana": "on",
        "transcrever-video": "on",
        "varrer-squads": "on",
        "comentar-pendencia": "name-only",
        "cortar-youtube": "name-only",
        "executar-bateria-qa": "name-only",
        "renderizar-newsletter-html": "name-only",
        "revisar-carrossel": "name-only",
        "revisar-codigo-pagina": "name-only",
        "revisar-estrategia": "name-only",
        "revisar-newsletter": "name-only",
        "revisar-newsletter-visual": "name-only",
        "revisar-visual": "name-only",
        "testar-pagina": "name-only",
        "ver-carrossel": "name-only",
        "revisar-roteiro": "name-only",
        "revisar-copy": "name-only",
        "revisar-linkedin": "name-only",
        "revisar-criativo": "name-only"
    }
}
