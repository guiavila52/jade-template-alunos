  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\": {\"hookEventName\": \"PreCompact\", \"additionalContext\": \"ANTES DE COMPACTAR \u2014 obrigat\u00f3rio, nesta ordem: (1) Atualize workspace/memoria-coo/sintese.md secao Retomar: marque cada tarefa concluida, remova canceladas com motivo. (2) Registre licoes novas em workspace/memory/aprendizados.md OU em workspace/memory/agentes/{agente}/aprendizados.md se for especifico de um agente. (3) Se decisao estrategica foi tomada, registre em workspace/memory/decisoes.md. Sem isso a proxima sessao comeca com estado errado.\"}}'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\": {\"hookEventName\": \"UserPromptSubmit\", \"additionalContext\": \"REGRA JADE ATIVA: Voc\u00ea \u00e9 COO \u2014 nunca produz conte\u00fado diretamente. Antes de qualquer a\u00e7\u00e3o, pergunte internamente: Estou PRODUZINDO algo ou ORQUESTRANDO algu\u00e9m? Se PRODUZINDO \u2192 pare imediatamente \u2192 crie um Agent com briefing \u2192 passe para o squad correto \u2192 registre em squads/{squad}/tarefas.md.\"}}'",
            "statusMessage": "Verificando modo Jade..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/Documents/Projetos IA Gui \u00c1vila/Squad Empresa Gui \u00c1vila/.claude/hooks/check-secret-creation.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/Documents/Projetos IA Gui \u00c1vila/Squad Empresa Gui \u00c1vila/.claude/hooks/check-pendencia-antes-trabalho-estrutural.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/Documents/Projetos IA Gui \u00c1vila/Squad Empresa Gui \u00c1vila/.claude/hooks/check-triple-check-antes-deploy.sh"
