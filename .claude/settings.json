        "matcher": "mcp__claude_ai_ClickUp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-mcp-clickup-deprecated.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-bash-em-claude-paths.sh",
            "description": "Bloqueia Bash com escrita em .claude/settings.json, .claude/hooks/, .claude/commands/, .claude/agents/, ~/.claude.json, ~/.claude/mcp.json (Regra \u00a716, vetor R2 self-modification)"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-baseline-hash-claude.sh",
            "description": "Verifica baseline sha256 de arquivos cr\u00edticos do Claude (~/.claude.json, hooks, settings) em background \u2014 Regra \u00a716 vetor R1 (Mini Shai-Hulud, CVE-2025-59536). N\u00c3O bloqueia, apenas warn em diverg\u00eancia."
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-agent-sem-skill-recente.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-mostrar-pro-gui-sem-revisor.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-comandos-destrutivos.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/.claude/hooks/check-publicacao-template.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/sessionstart-jade-autoload.sh",
            "description": "Autoload manual operacional Jade + top 5 fila ClickUp (list 901327194775) + instru\u00e7\u00e3o \u00a715 (Jade decide com opini\u00e3o). Regra \u00a711/\u00a716."
          }
        ]
      }
    ]
  },
