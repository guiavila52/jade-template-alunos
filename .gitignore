# macOS
.DS_Store
._.DS_Store
**/.DS_Store

# Editores
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependências
node_modules/

# Builds
dist/
.astro/
.vercel/
.next/
out/

# Variáveis de ambiente — Regra Inviolável #21
# Padrão: secrets em .env.local (gitignored), template em .env.example (versionado).
# Único .env.local oficial do squad: app/.env.local (app/ está ignorado abaixo, então herda).
.env
.env.*
!.env.example

# Backups de migração / refatoração
*.preFix*
*.preMigracao
*.preMentoriaV2
*.preMentoriaPrecosV2
*.preHeroFotoV3
*.preUrlsRetrofit98
*.preSlider
*.bloqueado
*.bak

# Templates / git aninhado
workspace/output/dev/squad-template-alunos/.git/

# Outputs de trabalho (não devem ser commitados)
workspace/output/
squad-fisico/output/
output/

# Worktrees git interno
.claude/worktrees/

# Duplicatas iCloud (arquivos com " 2", " 3", " 4" no nome)
* 2.md
* 3.md
* 4.md
* 2.sh
* 2.json
* 2.py
* 2/

# Hooks temporariamente desligados
*.tempoff

# Next antigo (repo separado, mantido fisicamente — Regra #18)
app/

# Cache do Claude Code (sessão)
.claude/cache/
.claude/scheduled_tasks.lock

# Caches Python
**/__pycache__/
*.pyc

# baseline-hashes.json muda toda vez que arquivos críticos legítimos mudam (localmachine)
workspace/output/seguranca/baseline-hashes.json
workspace/output/seguranca/last-check-status.txt
workspace/output/seguranca/*.log

workspace/infra/signoz/data/

.pre-commit-cache/
privado/
package-lock.json
*.bak-*

# ============================================================
# DADOS PESSOAIS DO OPERADOR — nunca commitar
# Protege seus dados se você criar um repo pessoal deste squad
# ============================================================

# Segundo cérebro (conhecimento pessoal — fica só na sua máquina)
segundo-cerebro/**
!segundo-cerebro/
!segundo-cerebro/*/
!segundo-cerebro/**/README.md

# Estado operacional (gerado em uso — não deve ser commitado)
workspace/memory/
workspace/output/

# Aprendizados acumulados (específicos do seu negócio)
squads/*/aprendizados.md
squads/*/agentes/*/aprendizados.md

# Histórico de mudanças pessoal
workspace/historico-mudancas/
